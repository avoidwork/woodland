{
  "name": "woodland",
  "version": "20.2.10",
  "description": "High-performance HTTP framework",
  "keywords": [
    "api",
    "framework",
    "http",
    "https",
    "middleware",
    "rest",
    "router",
    "routing"
  ],
  "homepage": "https://github.com/avoidwork/woodland",
  "bugs": {
    "url": "https://github.com/avoidwork/woodland/issues"
  },
  "license": "BSD-3-Clause",
  "author": "Jason Mulligan <jason.mulligan@avoidwork.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avoidwork/woodland.git"
  },
  "bin": {
    "woodland": "dist/cli.cjs"
  },
  "source": "src/woodland.js",
  "files": [
    "dist",
    "tpl",
    "types"
  ],
  "type": "module",
  "main": "dist/woodland.cjs",
  "types": "types/woodland.d.ts",
  "exports": {
    "types": "./types/woodland.d.ts",
    "import": "./dist/woodland.js",
    "require": "./dist/woodland.cjs"
  },
  "scripts": {
    "benchmark": "npm install express fastify --no-save && node benchmark.js",
    "build": "npm run rollup",
    "changelog": "auto-changelog -p",
    "clean": "rimraf dist coverage coverage.txt",
    "coverage": "c8 --reporter=text node --test tests/**/*.test.js 2>&1 | sed -n '/^---/,$p' > coverage.txt",
    "fix": "oxlint --fix src tests && oxfmt src tests --write",
    "lint": "oxlint src tests && oxfmt src tests --check",
    "prepare": "husky",
    "prebuild": "npm run clean",
    "rollup": "rollup --config",
    "test": "npm run lint && node --test tests/**/*.test.js",
    "test:cli": "node --test tests/unit/cli.test.js",
    "test:watch": "node --test --watch tests/**/*.test.js"
  },
  "dependencies": {
    "mime-db": "^1.54.0",
    "precise": "^4.0.3",
    "tiny-coerce": "^3.0.2",
    "tiny-etag": "^4.0.5",
    "tiny-lru": "^11.4.5"
  },
  "devDependencies": {
    "auto-changelog": "^2.5.0",
    "c8": "^11.0.0",
    "husky": "^9.1.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "pre-commit": "^1.2.2",
    "rimraf": "^6.0.1",
    "rollup": "^4.50.1"
  },
  "c8": {
    "branches": 100,
    "check-coverage": true,
    "exclude": [
      "dist/**",
      "benchmarks/**",
      "test-files/**",
      "tpl/**",
      "types/**",
      "tests/**",
      "rollup.config.js",
      "benchmark.js"
    ],
    "functions": 100,
    "lines": 100,
    "reporter": [
      "text",
      "html",
      "lcov"
    ],
    "statements": 100
  },
  "engines": {
    "node": ">=17.0.0"
  },
  "engineStrict": true
}
